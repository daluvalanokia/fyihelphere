@{
    ViewData["Title"] = "About FYI Help Here";
}
<div style="max-width:800px;margin:40px auto;padding:0 20px">
    <div style="text-align:center;margin-bottom:40px">
        <div style="width:80px;height:80px;background:linear-gradient(135deg,#e74c3c,#c0392b);border-radius:20px;display:inline-flex;align-items:center;justify-content:center;font-size:36px;color:white;margin-bottom:16px">
            <i class="fas fa-road"></i>
        </div>
        <h1 style="font-size:32px;font-weight:800;color:#222">FYI Help Here</h1>
        <p style="color:#888;font-size:16px">Road Issue Reporter — Helping communities stay safe</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:40px">
        <div class="feature-card"><i class="fas fa-map-location-dot"></i><h3>Live Navigation</h3><p>Real-time GPS tracking with turn-by-turn navigation</p></div>
        <div class="feature-card"><i class="fas fa-triangle-exclamation"></i><h3>Report Issues</h3><p>Quickly report road hazards, potholes, and debris</p></div>
        <div class="feature-card"><i class="fas fa-camera"></i><h3>Photo Upload</h3><p>Capture and upload photos directly from your device</p></div>
        <div class="feature-card"><i class="fas fa-envelope-open-text"></i><h3>Direct Alerts</h3><p>Send reports directly to city maintenance departments</p></div>
    </div>
    <div style="background:#f8f9fa;border-radius:14px;padding:30px;text-align:center">
        <p style="color:#555;line-height:1.7">FYI Help Here empowers citizens to quickly report road maintenance issues directly to city and county departments. With GPS location, photo capture, and direct notifications to transportation authorities, help is just one tap away.</p>
        <a href="/" style="display:inline-block;background:#e74c3c;color:white;padding:12px 28px;border-radius:10px;text-decoration:none;font-weight:600;margin-top:16px"><i class="fas fa-map"></i> Open Live Map</a>
    </div>
</div>
<style>
.feature-card{background:#fff;border:1.5px solid #f0f0f0;border-radius:14px;padding:24px;text-align:center;transition:transform .2s,box-shadow .2s}
.feature-card:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.08)}
.feature-card i{font-size:28px;color:#e74c3c;margin-bottom:12px;display:block}
.feature-card h3{margin:0 0 8px;font-size:16px;font-weight:700;color:#222}
.feature-card p{margin:0;font-size:13px;color:#666;line-height:1.5}
</style>
