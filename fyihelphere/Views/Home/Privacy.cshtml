@{
    ViewData["Title"] = "Privacy Policy";
}
<div style="max-width:700px;margin:40px auto;padding:0 20px">
    <h1 style="font-size:28px;font-weight:800">Privacy Policy</h1>
    <p style="color:#888;margin-bottom:28px">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>
    <section style="margin-bottom:24px">
        <h2 style="font-size:18px;font-weight:700;color:#e74c3c">Location Data</h2>
        <p style="color:#555;line-height:1.7">FYI Help Here uses your device's GPS to show your current location on the map and to pre-fill coordinates when reporting road issues. Location data is only used during your active session and is included in reports you submit.</p>
    </section>
    <section style="margin-bottom:24px">
        <h2 style="font-size:18px;font-weight:700;color:#e74c3c">Photos & Uploads</h2>
        <p style="color:#555;line-height:1.7">Photos you upload are stored temporarily to be included in your report email. They are not shared beyond the designated department recipients.</p>
    </section>
    <section>
        <h2 style="font-size:18px;font-weight:700;color:#e74c3c">Contact</h2>
        <p style="color:#555;line-height:1.7">For privacy questions, contact us at <a href="mailto:privacy@fyihelphere.com" style="color:#e74c3c">privacy@fyihelphere.com</a>.</p>
    </section>
</div>
