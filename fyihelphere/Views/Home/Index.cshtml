@{
    ViewData["Title"] = "FYI Help Here";
    var mapsKey = ViewBag.GoogleMapsApiKey as string ?? "";
}

@section Styles {
<style>
  .splash { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:calc(100vh - 64px); padding:24px 20px; text-align:center; }
  .splash-icon { width:100px; height:100px; background:linear-gradient(135deg,#e74c3c,#c0392b); border-radius:28px; display:inline-flex; align-items:center; justify-content:center; font-size:44px; color:white; box-shadow:0 12px 40px rgba(231,76,60,.45); margin-bottom:28px; animation:float 3s ease-in-out infinite; }
  @@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  .splash h1 { font-size:36px; font-weight:900; color:#222; margin:0 0 10px; letter-spacing:-1px; }
  .splash p { font-size:17px; color:#888; margin:0 0 36px; max-width:420px; line-height:1.6; }
  .big-btn { background:linear-gradient(135deg,#e74c3c,#c0392b); color:white; border:none; border-radius:20px; padding:22px 48px; font-size:20px; font-weight:800; cursor:pointer; display:inline-flex; align-items:center; gap:14px; box-shadow:0 8px 32px rgba(231,76,60,.5); transition:all .25s; text-decoration:none; }
  .big-btn:hover { transform:translateY(-3px) scale(1.02); box-shadow:0 12px 40px rgba(231,76,60,.6); color:white; }
  .big-btn i { font-size:24px; }
  .steps-row { display:flex; gap:20px; margin-top:48px; flex-wrap:wrap; justify-content:center; }
  .step { background:#fff; border-radius:16px; padding:20px; width:160px; box-shadow:0 2px 12px rgba(0,0,0,.06); border:1.5px solid #f0f0f0; transition:transform .2s; }
  .step:hover { transform:translateY(-4px); }
  .step-num { width:36px; height:36px; background:var(--primary,#e74c3c); border-radius:50%; color:white; font-weight:800; font-size:16px; display:flex; align-items:center; justify-content:center; margin:0 auto 12px; }
  .step p { margin:0; font-size:13px; color:#666; line-height:1.4; }
  .step-icon { font-size:24px; color:#e74c3c; margin-bottom:8px; }
  .disclaimer { margin-top:32px; font-size:12px; color:#bbb; max-width:380px; }
</style>
}

<div class="splash">
  <div class="splash-icon"><i class="fas fa-road"></i></div>
  <h1>FYI Help Here</h1>
  <p>Spotted a road hazard, debris, or damage while driving? Report it to your city maintenance team in seconds.</p>

  <a href="/NeedCleanup" class="big-btn">
    <i class="fas fa-camera"></i>
    Report a Road Issue
  </a>

  <div class="steps-row">
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-icon"><i class="fas fa-camera"></i></div>
      <p>Take or upload a photo of the issue</p>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-icon"><i class="fas fa-map-pin"></i></div>
      <p>Location captured automatically</p>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-icon"><i class="fas fa-eye"></i></div>
      <p>Review details before sending</p>
    </div>
    <div class="step">
      <div class="step-num">4</div>
      <div class="step-icon"><i class="fas fa-paper-plane"></i></div>
      <p>Report sent to the right department</p>
    </div>
  </div>

  <p class="disclaimer"><i class="fas fa-lock" style="color:#27ae60"></i> Your location is only used for this report and is never stored on our servers without your consent.</p>
</div>
