<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>fyihelphere</AssemblyName>
    <RootNamespace>fyihelphere</RootNamespace>
    <!-- Suppress known SMTP-smuggling advisory warnings (protocol-level, no library fix) -->
    <NoWarn>NU1902;NU1903</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Razor.RuntimeCompilation" Version="8.0.15" />
    <PackageReference Include="MailKit"         Version="4.12.0" />
    <PackageReference Include="MimeKit"         Version="4.12.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>
</Project>
